# Desafio-Data · .env.example
# Copiar a .env (NO versionado) y poner el NOMBRE REAL de la red interna de pLANGUNE,
# detectado en el VPS con:
#   sudo docker network ls | grep -E 'plangune|desafio'
#   sudo docker inspect plangune-backend-1 \
#     --format '{{range $name, $_ := .NetworkSettings.Networks}}{{println $name}}{{end}}'
#
# Lo consume docker-compose.data.prod.yml (networks.plangune_internal.name).
PLANGUNE_INTERNAL_NETWORK=
