import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.neighbors import NearestNeighbors
import joblib
import os


class Recommend:

    def __init__(self,
                 model_path="knn_model.joblib",
                 scaler_path="scaler.joblib"):

        self.model_path = model_path
        self.scaler_path = scaler_path

        if os.path.exists(model_path) and os.path.exists(scaler_path):
            self.model = joblib.load(model_path)
            self.scaler = joblib.load(scaler_path)
        else:
            self.retrain()

    def retrain(self, k=None):

        X = np.load("embeddings.npy")

        self.scaler = StandardScaler()
        X_scaled = self.scaler.fit_transform(X)

        if k is None:
            k = min(10, len(X_scaled))

        self.model = NearestNeighbors(
            n_neighbors=k + 1,  # +1 because the query itself is returned
            metric="cosine"
        )

        self.model.fit(X_scaled)

        joblib.dump(self.model, self.model_path)
        joblib.dump(self.scaler, self.scaler_path)

    def predict(self, x, limit=10):

        x = np.asarray(x)
        x_scaled = self.scaler.transform(x.reshape(1, -1))

        _, indices = self.model.kneighbors(x_scaled)

        # remove self-match
        neighbor_indices = indices[0][1:]

        return neighbor_indices[:limit]


def recommend(x, limit=10, retrain=False):

    R = Recommend()

    if retrain:
        R.retrain()

    return R.predict(x, limit=limit)
